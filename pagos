<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Ruleta Calculadora 1.1</title>
    <style>
        body { margin: 0; background: #004d00; overflow-y: auto; min-height: 100vh; display: flex; flex-direction: column; align-items: center; font-family: sans-serif; }
        header { width: 100%; background: #222; color: #ffd700; padding: 10px; text-align: center; border-bottom: 3px solid #b8860b; box-sizing: border-box; }
        .logo-ruleta { width: 25px; height: 25px; border: 3px solid #ffd700; border-radius: 50%; display: inline-block; vertical-align: middle; margin-right: 8px; background: conic-gradient(red 0deg, red 180deg, black 180deg, black 360deg); }
        .tablero-container { position: relative; width: 100%; max-width: 400px; margin-top: 10px; padding-bottom: 250px; }
        .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #fff; border: 2px solid #fff; }
        .celda { height: 60px; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white; cursor: pointer; }
        .rojo { background: #d32f2f; } .negro { background: #212121; }
        .verde-zona { background: #388e3c; height: 50px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; border-bottom: 2px solid #fff; cursor: pointer; }
        .ficha { position: absolute; width: 28px; height: 28px; background: gold; border-radius: 50%; pointer-events: none; transform: translate(-50%, -50%); display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: bold; color: black; z-index: 500; border: 2px solid #b8860b; box-shadow: 1px 1px 2px rgba(0,0,0,0.5); }
        .panel { background: #333; color: white; padding: 15px; width: 100%; max-width: 400px; position: fixed; bottom: 0; z-index: 9999; border-top: 3px solid #b8860b; }
        .controles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 5px; margin-top: 8px; }
        button { cursor: pointer; padding: 8px; border: none; background: #444; color: white; border-radius: 4px; font-size: 11px; }
        #modalDetalle { display: none; position: fixed; top: 10%; left: 10%; width: 80%; background: #fff; color: black; padding: 20px; border-radius: 10px; z-index: 10000; box-shadow: 0 0 10px #000; max-height: 70%; overflow-y: auto; }
    </style>
</head>
<body>

<header>
    <div class="logo-ruleta"></div> <strong>Ruleta Calculadora 1.1</strong>
</header>

<div id="modalDetalle">
    <h3>Detalle Acumulado</h3>
    <div id="contenidoDetalle"></div>
    <div id="totalDetalle" style="font-weight: bold; margin-top: 10px; color: #d32f2f;"></div>
    <button style="background: #333; margin-top: 15px; width: 100%;" onclick="document.getElementById('modalDetalle').style.display='none'">Cerrar</button>
</div>

<div class="tablero-container" id="container">
    <div class="verde-zona">0 (Tríos/Caballos)</div>
    <div class="grid" id="tablero"></div>
</div>

<div class="panel">
    <div>Bank: $<span id="bank">10800</span> | Apuesta: $<span id="totalApostado">0</span></div>
    <div style="margin-top: 5px; font-weight: bold; color: #ffeb3b;">Acumulado Perdido: $<span id="acumulado">0</span></div>
    <input type="number" id="numSalido" placeholder="N° Salido" style="width: 100%; margin: 5px 0; padding: 5px; box-sizing: border-box;">
    <div class="controles">
        <button onclick="resolverTirada()">Calc</button>
        <button onclick="limpiarTablero()">Reset</button>
        <button onclick="repetirApuesta()">Repetir</button>
        <button onclick="doblarApuesta()">Doblar</button>
        <button onclick="mostrarDetalles()">Detalles</button>
        <button onclick="reiniciarSistema()" style="background: #b71c1c;">Reiniciar</button>
    </div>
</div>

<script>
    let bankroll = 10800, apuestas = [], ultimaJugada = [], historialAcumulado = [], perdidasAcumuladas = 0;
    const container = document.getElementById('container');
    const tablero = document.getElementById('tablero');
    let matrix = [];

    // Generar tablero
    for (let i = 0; i < 12; i++) {
        let fila = [(i*3)+3, (i*3)+2, (i*3)+1];
        matrix.push(fila);
        fila.forEach(n => {
            let div = document.createElement('div');
            div.className = 'celda ' + ([1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36].includes(n) ? 'rojo' : 'negro');
            div.innerText = n;
            tablero.appendChild(div);
        });
    }

    function procesarApuesta(target, mult, label, x, y, monto = 100) {
        if (bankroll >= monto) {
            bankroll -= monto;
            apuestas.push({target, mult, label, x, y, monto});
            let f = document.createElement('div');
            f.className = 'ficha'; f.style.left = x + 'px'; f.style.top = y + 'px';
            f.innerText = label; container.appendChild(f);
            updateUI();
        }
    }

    function reiniciarSistema() {
        if (confirm("¿Estás seguro de reiniciar todo el sistema?")) {
            bankroll = 10800; perdidasAcumuladas = 0; historialAcumulado = []; ultimaJugada = [];
            limpiarTablero();
        }
    }

    container.addEventListener('pointerdown', (e) => {
        if (e.clientY > (window.innerHeight - 200)) return;
        let rect = container.getBoundingClientRect();
        let x = e.clientX - rect.left; let y = e.clientY - rect.top;
        let cellW = rect.width / 3; let cellH = 60;
        let target = [], mult = 0, label = '', fx, fy;

        if (y < 50) { 
            let rx = x / rect.width;
            if (rx < 0.2) { target = [0,3]; mult = 18; label = '18x'; fx = cellW * 0.2; fy = 25; }
            else if (rx < 0.4) { target = [0,3,2]; mult = 12; label = '12x'; fx = cellW * 0.5; fy = 25; }
            else if (rx < 0.6) { target = [0]; mult = 36; label = '36x'; fx = rect.width/2; fy = 25; }
            else if (rx < 0.8) { target = [0,1,2]; mult = 12; label = '12x'; fx = cellW * 2.5; fy = 25; }
            else { target = [0,1]; mult = 18; label = '18x'; fx = cellW * 2.8; fy = 25; }
        } else {
            let y_tab = y - 50; let col = Math.floor(x/cellW); let fila = Math.floor(y_tab/cellH);
            if(fila > 11) return;
            let rx = (x % cellW) / cellW; let ry = (y_tab % cellH) / cellH;
            if (rx < 0.3 && ry < 0.3 && fila > 0 && col > 0) { target = [matrix[fila][col], matrix[fila-1][col], matrix[fila][col-1], matrix[fila-1][col-1]]; mult = 9; label = '9x'; fx = col*cellW; fy = (fila*cellH)+50; }
            else if (ry < 0.3 && fila > 0) { target = [matrix[fila][col], matrix[fila-1][col]]; mult = 18; label = '18x'; fx = (col*cellW)+(cellW/2); fy = (fila*cellH)+50; }
            else if (rx < 0.3 && col > 0) { target = [matrix[fila][col], matrix[fila][col-1]]; mult = 18; label = '18x'; fx = col*cellW; fy = (fila*cellH)+80; }
            else { target = [matrix[fila][col]]; mult = 36; label = '36x'; fx = (col*cellW)+(cellW/2); fy = (fila*cellH)+80; }
        }
        procesarApuesta(target, mult, label, fx, fy);
    });

    function updateUI() { 
        document.getElementById('bank').innerText = bankroll; 
        document.getElementById('totalApostado').innerText = apuestas.reduce((sum, a) => sum + a.monto, 0);
        document.getElementById('acumulado').innerText = perdidasAcumuladas;
    }
    
    function limpiarTablero() { apuestas = []; document.querySelectorAll('.ficha').forEach(f => f.remove()); updateUI(); }
    
    function resolverTirada() {
        ultimaJugada = [...apuestas];
        let n = parseInt(document.getElementById('numSalido').value);
        let g = 0;
        apuestas.forEach(a => { if(a.target.includes(n)) g += (a.monto * a.mult); });
        if (g > 0) { bankroll += g; perdidasAcumuladas = 0; historialAcumulado = []; } 
        else { apuestas.forEach(a => historialAcumulado.push(a)); perdidasAcumuladas += apuestas.reduce((sum, a) => sum + a.monto, 0); }
        alert("Resultado: " + (g > 0 ? "Ganaste $" + g : "Perdiste"));
        limpiarTablero();
    }

    function repetirApuesta() { ultimaJugada.forEach(a => procesarApuesta(a.target, a.mult, a.label, a.x, a.y, a.monto)); }
    function doblarApuesta() { let temp = [...apuestas]; temp.forEach(a => procesarApuesta(a.target, a.mult, a.label, a.x, a.y, a.monto)); }
    function mostrarDetalles() {
        let total = 0;
        let d = historialAcumulado.map(a => { total += a.monto; return `A ${a.target.join(',')}: $${a.monto} (${a.label})`; }).join('<br>');
        document.getElementById('contenidoDetalle').innerHTML = d || "No hay apuestas.";
        document.getElementById('totalDetalle').innerText = "Total Acumulado: $" + total;
        document.getElementById('modalDetalle').style.display = 'block';
    }
</script>
</body>
</html>
